{
  "compilerOptions": {
      "target": "ES2020",
      "module": "ES2020",
      "outDir": "./dist",
      "moduleResolution": "Node",
      "strict": true,
      "types": ["node"],
      "typeRoots": ["node_modules/@types"],
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
  },
  "exclude": ["__tests__"],
  "include": ["src"]
}